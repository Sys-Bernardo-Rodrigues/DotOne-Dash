# My Dot Growth — API Node. Copie para server/.env

PORT=4000
CLIENT_ORIGIN=http://localhost:5173
ENABLE_HTTPS=false
SSL_CERT_FILE=
SSL_KEY_FILE=

# MongoDB (Docker: compose na raiz; banco mydotgrowth)
MONGODB_URI=mongodb://admin:admin123@localhost:27017/mydotgrowth?authSource=admin

# JWT — em produção exige pelo menos 24 chars com maiúscula/minúscula/número/símbolo
JWT_SECRET=Troque-por-chave-secreta-forte-complexa-123!
JWT_EXPIRES_IN=7d

# Login do painel administrativo (/login)
# — Conta sistema: acesso total ao /adm (super_admin).
# — Utilizadores Mongo: e-mail + senha definida ao criar o utilizador no /adm; perfil Administrador = /adm completo; outros perfis = só cliente(s) ou /adm/home se tiverem 2+ clientes.
ADMIN_EMAIL=admin@mydotgrowth.local
ADMIN_PASSWORD=Troque-por-senha-forte-complexa-123!

# Integrações de marketing — também configurável em Configurações → Integrações (painel)
# Valores abaixo são importados na 1.ª execução se a BD estiver vazia
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4000/api/integrations/meta/callback
API_PUBLIC_URL=http://localhost:4000

# Criptografia de tokens OAuth (recomendado: chave própria com 32+ chars)
INTEGRATION_ENCRYPTION_KEY=

# Google Ads — https://ads.google.com/aw/apicenter
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_REDIRECT_URI=http://localhost:4000/api/integrations/google/callback

# Sync automático diário de integrações (mês corrente)
ENABLE_INTEGRATION_CRON=false
INTEGRATION_CRON_HOUR=6
INTEGRATION_CRON_CHECK_MS=900000

# Notificações de alertas (e-mail + Slack)
ENABLE_INTEGRATION_NOTIFICATIONS=false
INTEGRATION_NOTIFY_EMAILS=admin@mydotgrowth.local
INTEGRATION_NOTIFY_COOLDOWN_MS=86400000
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mydotgrowth.local

# Relatório semanal por e-mail (segunda-feira por padrão)
ENABLE_WEEKLY_REPORT=false
WEEKLY_REPORT_DAY=1
WEEKLY_REPORT_HOUR=8
WEEKLY_REPORT_CHECK_MS=3600000
